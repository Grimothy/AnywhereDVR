# ── Host port mapping ──────────────────────────────────────
# The port exposed to your host machine (containers always use 3000 internally)
PORT=3001

# ── Timezone ───────────────────────────────────────────────
TZ=America/New_York

# ── TMDB (optional) ───────────────────────────────────────
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

